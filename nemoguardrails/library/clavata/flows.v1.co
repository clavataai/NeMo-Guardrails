#### POLICY DETECTION RAILS ####

# INPUT RAILS

define subflow clavata check input
  """Check if the user input is benign."""
  $is_match = execute DetectPolicyMatchAction(rail="input", text=$user_message)

  if $is_match
    bot refuse to respond
    stop


# OUTPUT RAILS

define subflow clavata check output
  """Check if the bot output is benign."""
  $is_match = execute DetectPolicyMatchAction(rail="output", text=$bot_message)

  if $is_match
    bot refuse to respond
    stop
